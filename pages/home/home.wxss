.page-home {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

/* ── 全屏背景图 ── */
.bg-full {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* ── 前景内容层 ── */
.content-overlay {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.home-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #2C3E50;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(255,255,255,0.8);
}
.home-sub {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 40rpx;
  text-shadow: 0 1rpx 4rpx rgba(255,255,255,0.8);
}

.home-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* ── 关卡卡片（整体背景框） ── */
.level-card {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(8rpx);
  border: 2rpx solid rgba(224,230,237,0.6);
  border-radius: 24rpx;
  padding: 24rpx 16rpx 20rpx;
  text-align: center;
  position: relative;
  transition: all 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.level-card:active {
  transform: scale(0.95);
}

/* ── 固定尺寸外框 ── */
.card-frame {
  width: 180rpx;
  height: 160rpx;
  border: 3rpx solid #D6E2F0;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(248,250,251,0.8);
  margin-bottom: 14rpx;
}

.lv-num {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}
.lv-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

/* ── 剩余数量 ── */
.lv-remain {
  font-size: 20rpx;
  color: #aaa;
  font-weight: 400;
}

/* ── 已完成状态 ── */
.level-done {
  border-color: #A5D6A7;
  background: rgba(240,249,243,0.88);
}
.level-done .card-frame {
  border-color: #A5D6A7;
  background: rgba(232,248,238,0.8);
}
.level-done .lv-name {
  color: #2E7D32;
}
.level-done .lv-num {
  color: #66BB6A;
}
.level-done .lv-remain {
  color: #81C784;
}

.done-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  background: #4CAF50;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  line-height: 44rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(76,175,80,0.4);
  z-index: 2;
}
