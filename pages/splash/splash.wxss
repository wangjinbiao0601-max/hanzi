.splash-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #E8F0FE;
}

/* 背景图铺满全屏 */
.splash-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 开始按钮 - 底部居中 */
.start-btn {
  position: absolute;
  bottom: 15%;
  left: 50%;
  transform: translateX(-50%);
  width: 400rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.5);
  animation: btnPulse 2s ease-in-out infinite;
  z-index: 10;
}

.start-btn:active {
  transform: translateX(-50%) scale(0.95);
}

.start-btn-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
}

/* 按钮呼吸动画 */
@keyframes btnPulse {
  0%, 100% {
    box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.5);
    transform: translateX(-50%) scale(1);
  }
  50% {
    box-shadow: 0 12rpx 40rpx rgba(255, 107, 53, 0.7);
    transform: translateX(-50%) scale(1.05);
  }
}
